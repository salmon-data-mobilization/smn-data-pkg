{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dfo-pacific-science.github.io/smn-data-pkg/profiles/salmon-data-package/v0.2/profile.json",
  "title": "Salmon Data Package Profile",
  "description": "Custom Frictionless Data Package profile for Salmon Data Package (SDP) packages.",
  "type": "object",
  "required": [
    "profile",
    "resources"
  ],
  "properties": {
    "profile": {
      "const": "https://dfo-pacific-science.github.io/smn-data-pkg/profiles/salmon-data-package/v0.2/profile.json"
    },
    "resources": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "required": [
          "name",
          "path",
          "profile",
          "schema"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "profile": {
            "const": "tabular-data-resource"
          },
          "schema": {}
        }
      }
    }
  },
  "allOf": [
    {
      "properties": {
        "resources": {
          "contains": {
            "type": "object",
            "required": [
              "name",
              "path",
              "profile",
              "schema"
            ],
            "properties": {
              "name": {
                "const": "sdp_dataset"
              },
              "path": {
                "const": "metadata/dataset.csv"
              },
              "profile": {
                "const": "tabular-data-resource"
              },
              "schema": {
                "const": "https://dfo-pacific-science.github.io/smn-data-pkg/schema/frictionless/metadata/dataset.schema.json"
              }
            }
          }
        }
      }
    },
    {
      "properties": {
        "resources": {
          "contains": {
            "type": "object",
            "required": [
              "name",
              "path",
              "profile",
              "schema"
            ],
            "properties": {
              "name": {
                "const": "sdp_tables"
              },
              "path": {
                "const": "metadata/tables.csv"
              },
              "profile": {
                "const": "tabular-data-resource"
              },
              "schema": {
                "const": "https://dfo-pacific-science.github.io/smn-data-pkg/schema/frictionless/metadata/tables.schema.json"
              }
            }
          }
        }
      }
    },
    {
      "properties": {
        "resources": {
          "contains": {
            "type": "object",
            "required": [
              "name",
              "path",
              "profile",
              "schema"
            ],
            "properties": {
              "name": {
                "const": "sdp_column_dictionary"
              },
              "path": {
                "const": "metadata/column_dictionary.csv"
              },
              "profile": {
                "const": "tabular-data-resource"
              },
              "schema": {
                "const": "https://dfo-pacific-science.github.io/smn-data-pkg/schema/frictionless/metadata/column_dictionary.schema.json"
              }
            }
          }
        }
      }
    }
  ],
  "sdp:version": "sdp-0.2.0",
  "sdp:metadataResources": [
    {
      "name": "sdp_dataset",
      "path": "metadata/dataset.csv",
      "profile": "tabular-data-resource",
      "title": "SDP dataset metadata",
      "description": "Dataset-level metadata.",
      "schema": "https://dfo-pacific-science.github.io/smn-data-pkg/schema/frictionless/metadata/dataset.schema.json",
      "sdp:requirement": "required"
    },
    {
      "name": "sdp_tables",
      "path": "metadata/tables.csv",
      "profile": "tabular-data-resource",
      "title": "SDP tables metadata",
      "description": "Table-level metadata.",
      "schema": "https://dfo-pacific-science.github.io/smn-data-pkg/schema/frictionless/metadata/tables.schema.json",
      "sdp:requirement": "required"
    },
    {
      "name": "sdp_column_dictionary",
      "path": "metadata/column_dictionary.csv",
      "profile": "tabular-data-resource",
      "title": "SDP column dictionary metadata",
      "description": "Column-level metadata.",
      "schema": "https://dfo-pacific-science.github.io/smn-data-pkg/schema/frictionless/metadata/column_dictionary.schema.json",
      "sdp:requirement": "required"
    },
    {
      "name": "sdp_codes",
      "path": "metadata/codes.csv",
      "profile": "tabular-data-resource",
      "title": "SDP codes metadata",
      "description": "Controlled code list metadata.",
      "schema": "https://dfo-pacific-science.github.io/smn-data-pkg/schema/frictionless/metadata/codes.schema.json",
      "sdp:requirement": "conditional",
      "sdp:condition": "Required when any column_dictionary.csv row has column_role equal to categorical."
    }
  ],
  "sdp:rules": "https://dfo-pacific-science.github.io/smn-data-pkg/schema/sdp.rules.yaml"
}
